[
  {
    "id": "php-fpm",
    "name": "PHP-FPM",
    "category": "php",
    "description": "PHP FastCGI Process Manager（默认版本）",
    "packages": {
      "brew": "php",
      "yum": "php-fpm",
      "dnf": "php-fpm",
      "apt": "php-fpm"
    },
    "systemd_unit": "php-fpm.service",
    "launchctl_label": "homebrew.mxcl.php",
    "pgrep_names": ["php-fpm"],
    "config_files": [
      {"path": "/etc/php-fpm.conf", "label": "主配置文件"},
      {"path": "/etc/php-fpm.d/www.conf", "label": "进程池配置"},
      {"path": "/usr/local/etc/php/php-fpm.conf", "label": "主配置文件 (Homebrew)"},
      {"path": "/usr/local/etc/php/php-fpm.d/www.conf", "label": "进程池配置 (Homebrew)"}
    ],
    "log_files": [
      {"path": "/var/log/php-fpm/error.log", "label": "错误日志"},
      {"path": "/usr/local/var/log/php-fpm.log", "label": "错误日志 (Homebrew)"}
    ],
    "data_dirs": [
      {"path": "/etc/php-fpm.d", "label": "进程池配置目录"},
      {"path": "/etc/php.d", "label": "PHP 模块配置目录"}
    ],
    "default_port": 9000
  },
