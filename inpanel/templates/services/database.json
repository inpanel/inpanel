    "config_files": [
      {"path": "/etc/my.cnf", "label": "主配置文件"},
      {"path": "/usr/local/etc/my.cnf", "label": "主配置文件 (Homebrew)"}
    ],
    "log_files": [
      {"path": "/var/log/mysqld.log", "label": "运行日志"},
      {"path": "/usr/local/var/mysql/error.log", "label": "错误日志 (Homebrew)"}
    ],
    "data_dirs": [
      {"path": "/var/lib/mysql", "label": "数据目录"},
      {"path": "/usr/local/var/mysql", "label": "数据目录 (Homebrew)"}
    ],
    "default_port": 3306
  },
