[
  {
    "id": "mariadb",
    "name": "MariaDB",
    "category": "database",
    "description": "MariaDB 数据库服务器",
    "packages": {
      "brew": "mariadb",
      "yum": "mariadb-server",
      "dnf": "mariadb-server",
      "apt": "mariadb-server"
    },
    "systemd_unit": "mariadb.service",
    "launchctl_label": "homebrew.mxcl.mariadb",
    "pgrep_names": ["mariadbd", "mysqld"],
    "pid_file": "/var/run/mariadb/mariadb.pid",
    "config_files": [
      {"path": "/etc/my.cnf", "label": "主配置文件"},
      {"path": "/etc/mysql/my.cnf", "label": "主配置文件 (Debian)"},
      {"path": "/usr/local/etc/my.cnf", "label": "主配置文件 (Homebrew)"}
    ],
    "log_files": [
      {"path": "/var/log/mariadb/mariadb.log", "label": "运行日志"},
      {"path": "/var/log/mysql/error.log", "label": "错误日志 (Debian)"}
    ],
    "data_dirs": [
      {"path": "/var/lib/mysql", "label": "数据目录"},
      {"path": "/usr/local/var/mysql", "label": "数据目录 (Homebrew)"}
    ],
    "default_port": 3306
  },
  {
    "id": "mysqld",
    "name": "MySQL",
