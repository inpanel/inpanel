    },
    "systemd_unit": "tomcat.service",
    "launchctl_label": "homebrew.mxcl.tomcat",
    "pgrep_names": ["tomcat", "java"],
    "config_files": [
      {"path": "/etc/tomcat/server.xml", "label": "主配置文件"}
    ],
    "log_files": [
      {"path": "/var/log/tomcat/catalina.out", "label": "运行日志"}
    ],
    "default_port": 8080
  },
  {
