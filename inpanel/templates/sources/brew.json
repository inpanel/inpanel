{
  "brew_builtin_taps": [
    "homebrew/core",
    "homebrew/cask"
  ],
  "brew_tap_templates": [
    {
      "id": "cask-versions",
      "name": "homebrew/cask-versions",
      "description": "提供旧版本和测试版应用的 cask",
      "url": "https://github.com/Homebrew/homebrew-cask-versions"
    },
    {
      "id": "services",
      "name": "homebrew/services",
      "description": "管理 macOS 服务",
      "url": "https://github.com/Homebrew/homebrew-services"
    },
    {
      "id": "fonts",
      "name": "homebrew/cask-fonts",
      "description": "字体安装",
      "url": "https://github.com/Homebrew/homebrew-cask-fonts"
    },
    {
      "id": "nginx",
      "name": "denji/homebrew-nginx",
      "description": "Nginx 开发版本",
      "url": "https://github.com/denji/homebrew-nginx"
    },
    {
      "id": "php",
      "name": "shivammathur/php",
      "description": "PHP 多版本管理",
      "url": "https://github.com/shivammathur/homebrew-php"
    },
    {
      "id": "redis",
      "name": "redis-stack/redis-stack",
      "description": "Redis Stack",
      "url": "https://github.com/redis-stack/homebrew-redis-stack"
    }
  ],
  "brew_builtin_mirrors": [
    {"name": "Homebrew 官方源", "url": "https://github.com/Homebrew/homebrew-core.git", "builtin": true},
    {"name": "清华大学 Homebrew", "url": "https://mirrors.tuna.tsinghua.edu.cn/git/homebrew/homebrew-core.git", "builtin": true},
    {"name": "中科大 Homebrew", "url": "https://mirrors.ustc.edu.cn/homebrew-core.git", "builtin": true},
    {"name": "阿里云 Homebrew", "url": "https://mirrors.aliyun.com/homebrew/homebrew-core.git", "builtin": true}
  ]
}
